{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "webhook": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "bindAddress": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "bindAddress", "path"]
    },
    "healingRequest": {
      "type": "object",
      "properties": {
        "workloadKind": { "type": "string", "enum": ["Deployment"] },
        "idempotencyWindowMinutes": { "type": "integer", "minimum": 1 },
        "rateLimit": {
          "type": "object",
          "properties": {
            "maxActions": { "type": "integer", "minimum": 1 },
            "windowMinutes": { "type": "integer", "minimum": 1 }
          },
          "required": ["maxActions", "windowMinutes"]
        },
        "blastRadius": {
          "type": "object",
          "properties": {
            "maxPodPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          },
          "required": ["maxPodPercentage"]
        },
        "circuitBreaker": {
          "type": "object",
          "properties": {
            "objectFailureThreshold": { "type": "integer", "minimum": 1 },
            "domainFailureThreshold": { "type": "integer", "minimum": 1 },
            "cooldownMinutes": { "type": "integer", "minimum": 1 },
            "scope": { "type": "string", "enum": ["Namespace", "Global"] }
          },
          "required": ["objectFailureThreshold", "domainFailureThreshold", "cooldownMinutes", "scope"]
        },
        "healthyRevision": {
          "type": "object",
          "properties": {
            "observeMinutes": { "type": "integer", "minimum": 1 },
            "requireNoCriticalAlerts": { "type": "boolean" }
          },
          "required": ["observeMinutes", "requireNoCriticalAlerts"]
        }
      },
      "required": ["workloadKind", "idempotencyWindowMinutes", "rateLimit", "blastRadius", "circuitBreaker", "healthyRevision"]
    }
  },
  "required": ["webhook", "healingRequest"]
}
