{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "webhook": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "bindAddress": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "bindAddress", "path"]
    },
    "healingRequest": {
      "type": "object",
      "properties": {
        "workloadKind": {
          "type": "string",
          "enum": ["Deployment", "StatefulSet"]
        },
        "snapshotPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "retentionMinutes": { "type": "integer", "minimum": 1 },
            "restoreTimeoutSeconds": { "type": "integer", "minimum": 1 },
            "maxSnapshotsPerWorkload": { "type": "integer", "minimum": 1 }
          },
          "required": [
            "enabled",
            "retentionMinutes",
            "restoreTimeoutSeconds",
            "maxSnapshotsPerWorkload"
          ]
        },
        "statefulSetPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "readOnlyOnly": { "type": "boolean" },
            "controlledActionsEnabled": { "type": "boolean" },
            "l2RollbackEnabled": { "type": "boolean" },
            "allowedNamespaces": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "approvalAnnotation": { "type": "string", "minLength": 1 },
            "requireEvidence": { "type": "boolean" },
            "freezeWindowMinutes": { "type": "integer", "minimum": 1 },
            "l2CandidateWindowMinutes": { "type": "integer", "minimum": 1 },
            "l2MaxDegradeRatePercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "required": [
            "enabled",
            "readOnlyOnly",
            "controlledActionsEnabled",
            "l2RollbackEnabled",
            "allowedNamespaces",
            "approvalAnnotation",
            "requireEvidence",
            "freezeWindowMinutes",
            "l2CandidateWindowMinutes",
            "l2MaxDegradeRatePercent"
          ]
        },
        "deploymentPolicy": {
          "type": "object",
          "properties": {
            "l2CandidateWindowMinutes": { "type": "integer", "minimum": 1 },
            "l2MaxDegradeRatePercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "l1SuccessRateMinPercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "l2SuccessRateMinPercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "l3DegradeRateMaxPercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "blockRateMaxPercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "required": [
            "l2CandidateWindowMinutes",
            "l2MaxDegradeRatePercent",
            "l1SuccessRateMinPercent",
            "l2SuccessRateMinPercent",
            "l3DegradeRateMaxPercent",
            "blockRateMaxPercent"
          ]
        },
        "productionGatePolicy": {
          "type": "object",
          "properties": {
            "sampleWindowMinutes": { "type": "integer", "minimum": 1 },
            "failureRatioBlockPercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "required": ["sampleWindowMinutes", "failureRatioBlockPercent"]
        },
        "releaseReadinessPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxOpenIncidents": { "type": "integer", "minimum": 0 },
            "requireRollbackCandidate": { "type": "boolean" },
            "drillEvidenceTTLMinutes": { "type": "integer", "minimum": 1 },
            "allowedDecisions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["allow", "degrade", "block"]
              },
              "minItems": 1
            }
          },
          "required": [
            "enabled",
            "maxOpenIncidents",
            "requireRollbackCandidate",
            "drillEvidenceTTLMinutes",
            "allowedDecisions"
          ]
        },
        "apiContractPolicy": {
          "type": "object",
          "properties": {
            "compatibilityClass": {
              "type": "string",
              "enum": [
                "backward-compatible",
                "migration-required",
                "version-bump-required"
              ]
            },
            "migrationPlanRef": { "type": "string" },
            "versionBumpWindow": { "type": "string" },
            "riskLevel": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "requireStatusFields": { "type": "boolean" }
          },
          "required": [
            "compatibilityClass",
            "migrationPlanRef",
            "versionBumpWindow",
            "riskLevel",
            "requireStatusFields"
          ]
        },
        "maintenanceWindows": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}-\\d{2}:\\d{2}$"
          }
        },
        "soakTimePolicies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string", "minLength": 1 },
              "severity": { "type": "string", "minLength": 1 },
              "durationSec": { "type": "integer", "minimum": 1 },
              "minSamples": { "type": "integer", "minimum": 1 }
            },
            "required": ["category", "severity", "durationSec", "minSamples"]
          }
        },
        "namespaceBudget": {
          "type": "object",
          "properties": {
            "blockingThresholdPercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "minTotalWorkloads": { "type": "integer", "minimum": 1 },
            "fallbackUnhealthyCount": { "type": "integer", "minimum": 1 }
          },
          "required": [
            "blockingThresholdPercent",
            "minTotalWorkloads",
            "fallbackUnhealthyCount"
          ]
        },
        "emergencyTry": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxAttempts": { "type": "integer", "minimum": 1 }
          },
          "required": ["enabled", "maxAttempts"]
        },
        "idempotencyWindowMinutes": { "type": "integer", "minimum": 1 },
        "rateLimit": {
          "type": "object",
          "properties": {
            "maxActions": { "type": "integer", "minimum": 1 },
            "windowMinutes": { "type": "integer", "minimum": 1 }
          },
          "required": ["maxActions", "windowMinutes"]
        },
        "blastRadius": {
          "type": "object",
          "properties": {
            "maxPodPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "required": ["maxPodPercentage"]
        },
        "circuitBreaker": {
          "type": "object",
          "properties": {
            "objectFailureThreshold": { "type": "integer", "minimum": 1 },
            "domainFailureThreshold": { "type": "integer", "minimum": 1 },
            "cooldownMinutes": { "type": "integer", "minimum": 1 },
            "scope": { "type": "string", "enum": ["Namespace", "Global"] }
          },
          "required": [
            "objectFailureThreshold",
            "domainFailureThreshold",
            "cooldownMinutes",
            "scope"
          ]
        },
        "healthyRevision": {
          "type": "object",
          "properties": {
            "observeMinutes": { "type": "integer", "minimum": 1 },
            "requireNoCriticalAlerts": { "type": "boolean" }
          },
          "required": ["observeMinutes", "requireNoCriticalAlerts"]
        }
      },
      "required": [
        "workloadKind",
        "snapshotPolicy",
        "statefulSetPolicy",
        "deploymentPolicy",
        "productionGatePolicy",
        "releaseReadinessPolicy",
        "apiContractPolicy",
        "maintenanceWindows",
        "soakTimePolicies",
        "namespaceBudget",
        "emergencyTry",
        "idempotencyWindowMinutes",
        "rateLimit",
        "blastRadius",
        "circuitBreaker",
        "healthyRevision"
      ]
    }
  },
  "required": ["webhook", "healingRequest"]
}
